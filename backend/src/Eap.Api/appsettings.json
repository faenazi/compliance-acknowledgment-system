{
  "ConnectionStrings": {
    "EapDatabase": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Ldap": {
    "Host": "",
    "Port": 389,
    "UseSsl": false,
    "Domain": "",
    "BaseDn": "",
    "BindDn": "",
    "BindPassword": "",
    "UserSearchFilter": "(&(objectClass=user)(sAMAccountName={username}))",
    "TimeoutSeconds": 15,
    "Attributes": {
      "Username": "sAMAccountName",
      "DisplayName": "displayName",
      "Email": "mail",
      "Department": "department",
      "JobTitle": "title",
      "MemberOf": "memberOf",
      "DirectoryReference": "objectGUID"
    }
  },
  "Identity": {
    "Provisioning": {
      "AssignEndUserRoleOnProvision": true,
      "SystemAdministrators": []
    },
    "Seed": {
      "Enabled": true
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ],
    "Properties": {
      "Application": "Eap.Api"
    }
  },
  "AllowedHosts": "*"
}
