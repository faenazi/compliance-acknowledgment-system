{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=EapDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True"
  },
  "Infrastructure": {
    "EnableSensitiveDataLogging": false
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "Eap.Api"
    }
  },
  "AllowedHosts": "*"
}
